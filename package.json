{
  "name": "umwelten",
  "version": "0.4.11",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp-serve": {
      "types": "./dist/habitat/mcp-serve/index.d.ts",
      "import": "./dist/habitat/mcp-serve/index.js"
    }
  },
  "bin": {
    "umwelten": "dist/cli/entry.js"
  },
  "description": "Habitat agent environments, multi-provider LLM access, and systematic model evaluation",
  "scripts": {
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:coverage": "vitest run --coverage --reporter=verbose",
    "lint": "eslint src --ext .ts,.tsx",
    "build": "tsc",
    "build:bridge": "esbuild src/habitat/bridge/server.ts --bundle --platform=node --target=node20 --outfile=dist/bridge/server.js --external:@modelcontextprotocol/sdk",
    "cli": "NODE_OPTIONS='--no-deprecation' tsx src/cli/entry.ts",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "knip": "knip"
  },
  "keywords": [
    "llm",
    "evaluation",
    "ai",
    "testing"
  ],
  "author": "The Focus AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git"
  },
  "homepage": "https://umwelten.thefocus.ai",
  "bugs": {
    "url": "https://github.com/The-Focus-AI/umwelten/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LLM.txt",
    "LICENSE",
    "env.template"
  ],
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@ai-sdk/google": "^2.0.51",
    "@ai-sdk/openai-compatible": "^1.0.29",
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@google/generative-ai": "^0.24.1",
    "@grammyjs/files": "^1.2.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.0.2",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@tavily/core": "^0.7.2",
    "@types/react": "^19.2.14",
    "ai": "^5.0.115",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "discord.js": "^14.26.1",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.6.0",
    "file-type": "^22.0.1",
    "fullscreen-ink": "^0.1.0",
    "glob": "^13.0.6",
    "grammy": "^1.41.1",
    "gray-matter": "^4.0.3",
    "ink": "^6.8.0",
    "ollama-ai-provider-v2": "^1.5.5",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "tiktoken": "^1.0.22",
    "turndown": "^7.2.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@dagger.io/dagger": "^0.20.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.4",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "knip": "^5.88.1",
    "node-addon-api": "^8.6.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitepress": "2.0.0-alpha.12",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ai-sdk-llama-cpp",
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "axios": ">=1.15.0",
      "tar": ">=7.5.11",
      "minimatch@>=10.0.0": ">=10.2.3",
      "minimatch@<4.0.0": ">=3.1.3",
      "rollup": ">=4.59.0",
      "path-to-regexp@>=8.0.0": ">=8.4.0",
      "brace-expansion@>=4.0.0": ">=5.0.5",
      "picomatch@>=4.0.0": ">=4.0.4",
      "flatted": ">=3.4.2",
      "follow-redirects": ">=1.16.0",
      "express-rate-limit": ">=8.2.2",
      "fast-xml-parser": ">=5.6.0",
      "vite@>=7.0.0 <8.0.0": ">=7.3.2",
      "ajv@<6.14.0": ">=6.14.0",
      "yaml@>=2.0.0": ">=2.8.3",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13",
      "@anthropic-ai/sdk": ">=0.81.0"
    }
  }
}
