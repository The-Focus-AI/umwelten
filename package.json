{
  "name": "umwelten-workspace",
  "version": "0.4.12",
  "private": true,
  "type": "module",
  "description": "Umwelten monorepo workspace",
  "scripts": {
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:all": "pnpm test:run && pnpm test:integration",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "cli": "NODE_OPTIONS='--no-deprecation' tsx packages/cli/src/entry.ts",
    "smoke:cascade": "tsx scripts/smoke-test-cascade.ts",
    "docs:sync-assets": "rm -rf docs/public/dialogue && mkdir -p docs/public/dialogue && cp examples/dialogue-web/index.html docs/public/dialogue/index.html",
    "docs:dev": "pnpm run docs:sync-assets && vitepress dev docs",
    "docs:build": "pnpm run docs:sync-assets && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "knip": "knip"
  },
  "keywords": [
    "llm",
    "evaluation",
    "ai",
    "testing"
  ],
  "author": "The Focus AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git"
  },
  "homepage": "https://umwelten.thefocus.ai",
  "bugs": {
    "url": "https://github.com/The-Focus-AI/umwelten/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.0.8",
  "devDependencies": {
    "@dagger.io/dagger": "^0.21.7",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tavily/core": "^0.7.6",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@umwelten/cli": "workspace:*",
    "@umwelten/core": "workspace:*",
    "@umwelten/evaluation": "workspace:*",
    "@umwelten/habitat": "workspace:*",
    "@umwelten/protocols": "workspace:*",
    "@umwelten/sessions": "workspace:*",
    "@umwelten/ui": "workspace:*",
    "@vitejs/plugin-react": "^6.0.3",
    "ai": "^7.0.22",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "knip": "^6.26.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitepress": "2.0.0-alpha.18",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ai-sdk-llama-cpp",
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "axios": ">=1.15.0",
      "tar": ">=7.5.11",
      "minimatch@>=10.0.0": ">=10.2.3",
      "minimatch@<4.0.0": ">=3.1.3",
      "rollup": ">=4.59.0",
      "path-to-regexp@>=8.0.0": ">=8.4.0",
      "brace-expansion@>=4.0.0": ">=5.0.5",
      "picomatch@>=4.0.0": ">=4.0.4",
      "flatted": ">=3.4.2",
      "follow-redirects": ">=1.16.0",
      "express-rate-limit": ">=8.2.2",
      "fast-xml-parser": ">=5.6.0",
      "vite@>=7.0.0 <8.0.0": ">=7.3.2",
      "ajv@<6.14.0": ">=6.14.0",
      "yaml@>=2.0.0": ">=2.8.3",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13",
      "@anthropic-ai/sdk": ">=0.81.0"
    }
  }
}
