{
  "name": "@umwelten/evaluation",
  "version": "0.4.12",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "description": "Model evaluation, ranking, reporting, and session introspection",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git",
    "directory": "packages/evaluation"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@umwelten/core": "workspace:*",
    "ai": "^5.0.115",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "glob": "^13.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dagger.io/dagger": "^0.20.1",
    "@types/node": "^25.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
