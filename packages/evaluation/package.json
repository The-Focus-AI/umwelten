{
  "name": "@umwelten/evaluation",
  "version": "0.4.12",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "description": "Model evaluation, ranking, reporting, and session introspection",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git",
    "directory": "packages/evaluation"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@umwelten/core": "workspace:*",
    "@umwelten/sessions": "workspace:*",
    "ai": "^6.0.191",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "glob": "^13.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dagger.io/dagger": "^0.20.8",
    "@types/node": "^24.10.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
