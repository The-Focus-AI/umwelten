{
  "name": "@umwelten/core",
  "version": "0.4.12",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "description": "Core LLM runtime: cognition, stimulus, interaction, providers, and foundation modules",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.51",
    "@ai-sdk/openai-compatible": "^1.0.29",
    "@google/generative-ai": "^0.24.1",
    "@json-render/core": "^0.18.0",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "ai": "^5.0.115",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.6.0",
    "file-type": "^21.3.2",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "ollama-ai-provider-v2": "^3.5.0",
    "streammark": "^1.0.4",
    "tiktoken": "^1.0.22",
    "turndown": "^7.2.2",
    "undici": "^8.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
