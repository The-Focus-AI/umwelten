{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "rootDir": "src",
    "types": ["node"],
    "composite": true
  },
  "references": [
    { "path": "../core" },
    { "path": "../server" },
    { "path": "../habitat" },
    { "path": "../evaluation" },
    { "path": "../ui" },
    { "path": "../cli" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
