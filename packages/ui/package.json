{
  "name": "@umwelten/ui",
  "version": "0.4.12",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./cli/CLIInterface.js": "./src/cli/CLIInterface.ts",
    "./cli/DefaultCommands.js": "./src/cli/DefaultCommands.ts",
    "./cli/repl.js": "./src/cli/repl.ts",
    "./discord/discord-backfill-sessions.js": "./src/discord/discord-backfill-sessions.ts",
    "./*.js": {
      "types": "./src/*",
      "import": "./src/*.tsx"
    },
    "./**/*.js": {
      "types": "./src/**/*",
      "import": "./src/**/*.tsx"
    }
  },
  "description": "UI adapters: Telegram, Discord, TUI (React Ink), CLI interface",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git",
    "directory": "packages/ui"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.187",
    "@grammyjs/files": "^1.2.0",
    "@inkjs/ui": "^2.0.0",
    "@types/react": "^19.2.14",
    "@umwelten/core": "workspace:*",
    "@umwelten/evaluation": "workspace:*",
    "@umwelten/habitat": "workspace:*",
    "ai": "^6.0.191",
    "chalk": "^5.6.2",
    "discord.js": "^14.26.4",
    "fullscreen-ink": "^0.1.0",
    "grammy": "^1.43.0",
    "ink": "^6.8.0",
    "ora": "^9.4.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "@types/react-dom": "^19.2.3",
    "ink-testing-library": "^4.0.0",
    "react-dom": "^19.2.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
