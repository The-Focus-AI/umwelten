{
  "name": "@umwelten/cli",
  "version": "0.4.13",
  "type": "module",
  "main": "./src/cli.ts",
  "types": "./src/cli.ts",
  "bin": {
    "umwelten": "src/entry.ts"
  },
  "description": "CLI entry point for umwelten",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "cli": "NODE_OPTIONS='--no-deprecation' tsx src/entry.ts",
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@umwelten/core": "workspace:*",
    "@umwelten/protocols": "workspace:*",
    "@umwelten/habitat": "workspace:*",
    "@umwelten/evaluation": "workspace:*",
    "@umwelten/sessions": "workspace:*",
    "@umwelten/ui": "workspace:*",
    "ai": "^7.0.22",
    "file-type": "^22.0.1",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
