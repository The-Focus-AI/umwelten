{
  "name": "@umwelten/cli",
  "version": "0.4.12",
  "type": "module",
  "main": "./src/cli.ts",
  "types": "./src/cli.ts",
  "bin": {
    "umwelten": "src/entry.ts"
  },
  "description": "CLI entry point for umwelten",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "cli": "NODE_OPTIONS='--no-deprecation' tsx src/entry.ts",
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@umwelten/core": "workspace:*",
    "@umwelten/server": "workspace:*",
    "@umwelten/habitat": "workspace:*",
    "@umwelten/evaluation": "workspace:*",
    "@umwelten/ui": "workspace:*",
    "ai": "^5.0.115",
    "file-type": "^21.3.2",
    "ink": "^5.2.1",
    "react": "^19.1.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
