{
  "name": "@umwelten/sessions",
  "version": "0.4.13",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "description": "Session browsing, search, digest, learnings, and transcript tools for umwelten",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git",
    "directory": "packages/sessions"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@umwelten/core": "workspace:*",
    "@umwelten/ui": "workspace:*",
    "ai": "^7.0.22",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
