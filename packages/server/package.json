{
  "name": "@umwelten/server",
  "version": "0.4.12",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "description": "Network protocol layer: MCP server/client and A2A client/server scaffolding",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Focus-AI/umwelten.git",
    "directory": "packages/server"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@umwelten/core": "workspace:*",
    "@a2a-js/sdk": "^0.3.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^5.0.115",
    "undici": "^8.2.0",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
