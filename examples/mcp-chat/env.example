# LLM configuration for the chat agent
MCP_CHAT_PROVIDER=google
MCP_CHAT_MODEL=gemini-3-flash-preview

# Server configuration
MCP_CHAT_SERVER_URL=https://mcp.tezlabapp.com
MCP_CHAT_SCOPE=mcp

# OAuth callback listener for the local CLI
MCP_CHAT_OAUTH_PORT=3339
MCP_CHAT_OAUTH_TIMEOUT_MS=300000

# Optional paths
# MCP_CHAT_WORK_DIR=/absolute/path/to/.mcp-chat
# MCP_CHAT_SESSIONS_DIR=/absolute/path/to/.mcp-chat-sessions
# MCP_CHAT_AUTH_STORE=/absolute/path/to/tezlab-oauth.json

# Optional: explicitly opt in to command-capable tools
# Keep this false for the default read-only demo.
MCP_CHAT_ALLOW_COMMANDS=false

# Provider credentials for the language model itself
# GOOGLE_GENERATIVE_AI_API_KEY=
# OPENAI_API_KEY=