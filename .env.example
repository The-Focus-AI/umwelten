# OpenRouter API key for testing
OPENROUTER_API_KEY=your-openrouter-api-key

# Google Generative AI API key for testing
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# GitHub Personal Access Token for GitHub Models
GITHUB_TOKEN=your-github-personal-access-token

# MiniMax API key for direct MiniMax access
MINIMAX_API_KEY=your-minimax-api-key

# Optional: override MiniMax API base URL
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# Optional: Set to 'test' to use mock data
NODE_ENV=test
