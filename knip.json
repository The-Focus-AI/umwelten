{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignore": ["**/*.test.ts"]
    },
    "packages/cli": {
      "entry": ["src/index.ts", "src/entry.ts"],
      "project": ["src/**/*.ts"],
      "ignore": ["**/*.test.ts"]
    }
  }
}
